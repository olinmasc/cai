from backend.ai_routes import ai_router
import pandas as pd
import io
from datetime import datetime
from bson import ObjectId
from backend.database import invoices_collection, clients_collection

app = FastAPI(title="CAI — Autonomous GST Compliance", version="1.0.0")

app.add_middleware(
    CORSMiddleware,
    allow_origins=["http://localhost:5173", "http://127.0.0.1:5173"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# ── NEW: REAL-WORLD FILE UPLOAD ROUTER ─────────────────────────
upload_router = APIRouter(prefix="/clients", tags=["Client Data Upload"])


@upload_router.post("/{client_id}/upload-invoices")
async def upload_real_invoices(client_id: str, file: UploadFile = File(...)):
    """Real-world ingestion: Parses a CSV/Excel file from a CA and saves to MongoDB."""
    client = await clients_collection.find_one({"_id": ObjectId(client_id)})
    if not client:
        raise HTTPException(status_code=404, detail="Client not found")

    try:
        contents = await file.read()
        if file.filename.endswith('.csv'):
            df = pd.read_csv(io.BytesIO(contents))
        elif file.filename.endswith(('.xls', '.xlsx')):
            df = pd.read_excel(io.BytesIO(contents))
        else:
            raise HTTPException(
                status_code=400, detail="Only CSV or Excel files allowed")

        # Clean column names
        df = df.rename(columns=lambda x: str(x).strip())

        # Ensure minimum required columns exist
        if 'Invoice No' not in df.columns or 'Amount' not in df.columns:
            raise HTTPException(
                status_code=400, detail="File must contain 'Invoice No' and 'Amount' columns.")

        df = df.dropna(subset=['Invoice No', 'Amount'])

        invoices_to_insert = []
        for _, row in df.iterrows():
            invoices_to_insert.append({
                "client_id": client_id,
                "invoice_number": str(row.get('Invoice No', '')),
                "date": str(row.get('Date', datetime.utcnow().strftime("%Y-%m-%d"))),
                "party_name": str(row.get('Party Name', 'Unknown')),
                "gstin": str(row.get('GSTIN', '')),
                "amount": float(row.get('Amount', 0.0)),
                "gst_type": str(row.get('Type', 'PURCHASE')).upper(),
                "source": "excel_upload",
                "status": "pending",
                "uploaded_at": datetime.utcnow().isoformat()
            })

        if invoices_to_insert:
            await invoices_collection.insert_many(invoices_to_insert)

        return {
            "message": "Upload successful",
            "inserted_count": len(invoices_to_insert),
            "filename": file.filename
        }

    except Exception as e:
        raise HTTPException(
            status_code=500, detail=f"Failed to process file: {str(e)}")

app.include_router(upload_router)
# ───────────────────────────────────────────────────────────────

app.include_router(auth.router,           prefix="/auth",
                   tags=["Auth"])
app.include_router(clients.router,        prefix="/clients",
                   tags=["Clients"])
app.include_router(invoices.router,       prefix="/invoices",
                   tags=["Invoices"])
app.include_router(reconciliation.router,
                   prefix="/reconciliation",  tags=["Reconciliation"])
app.include_router(filings.router,        prefix="/filings",
                   tags=["Filings"])
app.include_router(ai_router)


@app.get("/")
async def root():
    return {"message": "CAI API is running", "version": "1.0.0"}
