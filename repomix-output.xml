from fastapi import APIRouter, Depends, HTTPException
from fastapi.responses import StreamingResponse
from backend.database import invoices_collection, reconciliations_collection, clients_collection, audit_logs_collection
from backend.models import NotifyClientRequest
from backend.dependencies import get_current_user, require_admin
from bson import ObjectId
from datetime import datetime
import os
import io
import pandas as pd
from reportlab.pdfgen import canvas
from twilio.rest import Client

# IMPORT YOUR REAL MACHINE LEARNING MODEL
from backend.ml_model import get_detector

router = APIRouter()


def serialize(doc) -> dict:
    doc["id"] = str(doc["_id"])
    del doc["_id"]
    return doc


@router.get("/{client_id}")
async def get_reconciliation(client_id: str, current_user=Depends(get_current_user)):
    records = await reconciliations_collection.find({"client_id": client_id}).to_list(length=500)
    return [serialize(r) for r in records]


@router.post("/run/{client_id}")
async def run_reconciliation(client_id: str, current_user=Depends(get_current_user)):
    invoices = await invoices_collection.find({"client_id": client_id, "status": "pending"}).to_list(length=500)

    # STRICT NO-FAKE-DATA POLICY
    if not invoices:
        raise HTTPException(
            status_code=400, detail="No pending invoices found! Please upload real Client Data (CSV/XML) first.")

    # RUN REAL MACHINE LEARNING PREDICTION
    detector = get_detector()
    scored_invoices = detector.predict_anomaly(invoices)

    current_month = datetime.utcnow().strftime("%Y-%m")
    reconciliation_records = []

    for inv in scored_invoices:
        is_anomaly = inv.get("is_anomaly", False)
        score = inv.get("anomaly_score", 0)

        status = "matched"
        reason = None
        carried_forward = False

        if is_anomaly:
            was_carried_forward = inv.get("carried_forward", False)
            if not was_carried_forward:
                status = "mismatch"
                reason = f"AI flagged anomalous pattern (Risk: {score}). Carried forward to check next month's filing."
                carried_forward = True
            else:
                status = "mismatch"
                reason = f"Persistent Anomaly across periods (Risk: {score}). Immediate Action Required."
                carried_forward = False

        record = {
            "client_id": client_id,
            "invoice_id": str(inv["_id"]),
            "party_name": inv["party_name"],
            "amount": inv["amount"],
            "month": current_month,
            "gstr2a_match": not is_anomaly,
            "mismatch_reason": reason,
            "carried_forward": carried_forward,
            "status": status,
            "risk": score,
            "reconciled_at": datetime.utcnow().isoformat()
        }

        await invoices_collection.update_one(
            {"_id": inv["_id"]},
            {"$set": {"status": "reconciled" if status ==
                      "matched" else "mismatch", "carried_forward": carried_forward}}
        )
        reconciliation_records.append(record)

    await reconciliations_collection.insert_many(reconciliation_records)

    matched = sum(
        1 for r in reconciliation_records if r["status"] == "matched")
    mismatched = len(reconciliation_records) - matched
    risk_score = int((mismatched / len(reconciliation_records)) * 100)

    await clients_collection.update_one({"_id": ObjectId(client_id)}, {"$set": {"risk_score": risk_score}})

    return {"message": "Reconciliation complete", "matched": matched, "mismatched": mismatched, "risk_score": risk_score}


@router.post("/approve/{exception_id}")
async def approve_exception(exception_id: str, current_admin=Depends(require_admin)):
    result = await reconciliations_collection.update_one(
        {"_id": ObjectId(exception_id)},
        {"$set": {"status": "approved"}}
    )
    if result.modified_count == 0:
        raise HTTPException(status_code=404, detail="Exception not found")

    await audit_logs_collection.insert_one({
        "action": "APPROVED_EXCEPTION",
        "user": current_admin["email"],
        "exception_id": exception_id,
        "timestamp": datetime.utcnow().isoformat()
    })
    return {"message": "Exception approved and logged"}


@router.post("/notify-client")
async def notify_client(req: NotifyClientRequest, current_admin=Depends(require_admin)):
    client = await clients_collection.find_one({"_id": ObjectId(req.client_id)})
    if not client or not client.get("phone"):
        raise HTTPException(
            status_code=400, detail="Client phone number missing")

    phone = client["phone"]
    account_sid = os.getenv("TWILIO_ACCOUNT_SID")
    auth_token = os.getenv("TWILIO_AUTH_TOKEN")
    twilio_number = os.getenv("TWILIO_WHATSAPP_NUMBER")

    message_body = f"Hi {client['name']}, {current_admin['firm_name']} here. Our AI detected a ₹{req.amount} mismatch on Invoice #{req.invoice_no}. Please upload the corrected invoice to our portal."

    if not account_sid or not auth_token:
        print(f"Twilio Mock: Sent WhatsApp to {phone}: {message_body}")
        return {"message": "Mock notification sent successfully"}

    try:
        tw_client = Client(account_sid, auth_token)
        tw_client.messages.create(
            body=message_body, from_=twilio_number, to=f"whatsapp:{phone}")
        return {"message": "WhatsApp message sent successfully"}
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Twilio Error: {str(e)}")


@router.get("/export-report/{client_id}")
async def export_report(client_id: str, format: str = "excel", current_admin=Depends(require_admin)):
    records = await reconciliations_collection.find({"client_id": client_id, "status": "mismatch"}).to_list(length=1000)
    if not records:
        raise HTTPException(status_code=404, detail="No anomalies to export")

    if format == "excel":
        df = pd.DataFrame(records)
        df = df[['party_name', 'invoice_id',
                 'amount', 'mismatch_reason', 'month']]

        output = io.BytesIO()
        with pd.ExcelWriter(output, engine='openpyxl') as writer:
            df.to_excel(writer, index=False, sheet_name='Anomalies')
        output.seek(0)

        return StreamingResponse(
            output,
            media_type="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            headers={
                "Content-Disposition": f"attachment; filename=GST_Mismatch_Report.xlsx"}
        )

    elif format == "pdf":
        buffer = io.BytesIO()
        p = canvas.Canvas(buffer)
        p.setFont("Helvetica-Bold", 16)
        p.drawString(100, 800, f"CAI — GST Reconciliation Report")

        p.setFont("Helvetica", 10)
        y = 750
        for rec in records:
            p.drawString(
                50, y, f"Invoice: {rec.get('invoice_id')} | Party: {rec.get('party_name')} | Amount: ₹{rec.get('amount')}")
            y -= 15
            p.drawString(50, y, f"Reason: {rec.get('mismatch_reason')}")
            y -= 30
            if y < 100:
                p.showPage()
                y = 800
        p.save()
        buffer.seek(0)

        return StreamingResponse(
            buffer,
            media_type="application/pdf",
            headers={
                "Content-Disposition": f"attachment; filename=GST_Mismatch_Report.pdf"}
        )
    else:
        raise HTTPException(
            status_code=400, detail="Invalid format. Use 'excel' or 'pdf'")
