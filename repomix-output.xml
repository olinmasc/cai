from fastapi import APIRouter, Depends, HTTPException, UploadFile, File
from backend.database import clients_collection, invoices_collection
from backend.models import ClientCreate, ClientUpdate, GSTValidationRequest
from backend.dependencies import get_current_user
from bson import ObjectId
from datetime import datetime
import xmltodict
import json

router = APIRouter()


def serialize(doc) -> dict:
    doc["id"] = str(doc["_id"])
    del doc["_id"]
    return doc


@router.get("/")
async def get_clients(current_user=Depends(get_current_user)):
    # FIX: Use the shared firm ID so Admins and Clerks see the same clients
    ca_id = current_user.get("ca_id", str(current_user["_id"]))
    clients = await clients_collection.find({"ca_id": ca_id}).to_list(length=100)
    return [serialize(c) for c in clients]


@router.post("/")
async def add_client(client: ClientCreate, current_user=Depends(get_current_user)):
    ca_id = current_user.get("ca_id", str(current_user["_id"]))
    existing = await clients_collection.find_one({"ca_id": ca_id, "gstin": client.gstin})
    if existing:
        raise HTTPException(
            status_code=400, detail="Client with GSTIN already exists")

    new_client = {
        "ca_id": ca_id,
        "name": client.name,
        "gstin": client.gstin,
        "phone": client.phone,
        "plan_type": client.plan_type,
        "status": "active",
        "risk_score": 0,
        "created_at": datetime.utcnow().isoformat()
    }
    result = await clients_collection.insert_one(new_client)
    new_client["id"] = str(result.inserted_id)
    del new_client["_id"]
    return new_client


@router.get("/{client_id}")
async def get_client(client_id: str, current_user=Depends(get_current_user)):
    client = await clients_collection.find_one({"_id": ObjectId(client_id)})
    if not client:
        raise HTTPException(status_code=404, detail="Client not found")
    return serialize(client)


@router.post("/validate-gst")
async def validate_gst(req: GSTValidationRequest, current_user=Depends(get_current_user)):
    is_valid = len(req.gstin) == 15 and req.gstin.startswith("27")
    return {
        "gstin": req.gstin,
        "is_valid": is_valid,
        "legal_name": "Validated Enterprise" if is_valid else "Unknown",
        "status": "Active" if is_valid else "Invalid GSTIN"
    }


@router.post("/{client_id}/upload-xml")
async def upload_tally_xml(client_id: str, file: UploadFile = File(...), current_user=Depends(get_current_user)):
    client = await clients_collection.find_one({"_id": ObjectId(client_id)})
    if not client:
        raise HTTPException(status_code=404, detail="Client not found")

    try:
        contents = await file.read()
        xml_data = xmltodict.parse(contents)

        messages = xml_data.get("ENVELOPE", {}).get(
            "BODY", {}).get("DATA", {}).get("TALLYMESSAGE", [])
        if not isinstance(messages, list):
            messages = [messages]

        invoices_to_insert = []
        for msg in messages:
            voucher = msg.get("VOUCHER")
            if not voucher:
                continue

            date_str = voucher.get(
                "DATE", datetime.utcnow().strftime("%Y%m%d"))
            party_name = voucher.get("PARTYLEDGERNAME", "Unknown Party")
            invoice_no = voucher.get(
                "VOUCHERNUMBER", f"TALLY-{datetime.utcnow().timestamp()}")

            amount = 0.0
            ledgers = voucher.get("LEDGERENTRIES.LIST", [])
            if not isinstance(ledgers, list):
                ledgers = [ledgers]
            for ledger in ledgers:
                amt = ledger.get("AMOUNT")
                if amt:
                    amount = abs(float(amt))

            invoices_to_insert.append({
                "client_id": client_id,
                "invoice_number": invoice_no,
                "date": date_str,
                "party_name": party_name,
                "gstin": voucher.get("PARTYGSTIN", ""),
                "amount": amount,
                "gst_type": "PURCHASE" if voucher.get("VOUCHERTYPENAME") == "Purchase" else "SALES",
                "source": "tally_xml",
                "status": "pending",
                "uploaded_at": datetime.utcnow().isoformat()
            })

        if invoices_to_insert:
            await invoices_collection.insert_many(invoices_to_insert)

        return {"message": f"Parsed {len(invoices_to_insert)} Tally XML invoices successfully.", "inserted_count": len(invoices_to_insert)}

    except Exception as e:
        raise HTTPException(
            status_code=500, detail=f"Failed to parse Tally XML: {str(e)}")
