"""
agents.py — CAI Multi-Agent Orchestration via LangGraph
"""

import random
import os
from datetime import datetime
from typing import TypedDict, Optional, Annotated
import operator
from dotenv import load_dotenv

from langgraph.graph import StateGraph, END
from langchain_groq import ChatGroq

ffrom backend.ml_model import get_detector
from backend.mlops import get_tracker, retrain_and_log

load_dotenv()

# ── LLM SETUP ─────────────────────────────────────────────────
groq_key = os.getenv("GROQ_API_KEY")
llm = ChatGroq(
    model="llama3-8b-8192",
    api_key=groq_key,
    temperature=0.3,
) if groq_key else None


# ── PIPELINE STATE ────────────────────────────────────────────

class PipelineState(TypedDict):
    client_id:           str
    client_name:         str
    period:              str
    ca_email:            str
    invoices:            list[dict]
    ingested_invoices:   list[dict]
    ingestion_source:    str
    ingestion_errors:    int
    reconciled_invoices: list[dict]
    matched_count:       int
    mismatch_count:      int
    anomalies:           list[dict]
    risk_score:          float
    filing_payload:      dict
    filing_status:       str
    nic_reference:       Optional[str]
    model_metrics:       dict
    run_id:              Optional[str]
    errors:              Annotated[list[str], operator.add]
    completed_at:        Optional[str]


# ── AGENT 1: INGESTION (PERCEIVE) ────────────────────────────

async def ingestion_agent(state: PipelineState) -> PipelineState:
    print(f"[Ingestion] Starting for client {state['client_name']}...")

    tracker = get_tracker()
    run_id = tracker.start_run(
        client_id=state["client_id"],
        period=state["period"],
        ca_email=state["ca_email"],
    )

    invoices = state.get("invoices", [])
    errors = 0
    ingested = []

    for inv in invoices:
        try:
            normalized = {
                "id":         inv.get("id", f"INV-{random.randint(1000, 9999)}"),
                "client_id":  state["client_id"],
                "date":       inv.get("date", datetime.utcnow().strftime("%Y-%m-%d")),
                "party_name": inv.get("party_name", "Unknown Supplier"),
                "gstin":      inv.get("gstin", ""),
                "amount":     float(inv.get("amount", 0)),
                "gst_type":   inv.get("gst_type", "PURCHASE").upper(),
                "source":     inv.get("source", "manual"),
                "status":     "ingested",
            }
            ingested.append(normalized)
        except Exception as e:
            errors += 1
            print(f"[Ingestion] Parse error: {e}")

    # ── DISABLED FALLBACK FOR REAL-WORLD USAGE ──
    # if not ingested:
    #     ingested = _generate_demo_invoices(state["client_id"], 20)
    #     print(f"[Ingestion] No invoices — generated {len(ingested)} demo invoices")
    if not ingested:
        print("[Ingestion] WARNING: No invoices found in the database for this client.")

    tracker.log_ingestion(
        total_invoices=len(ingested),
        source=state.get("ingestion_source", "manual"),
        parse_errors=errors,
        duration_seconds=0.5,
    )

    print(f"[Ingestion] Done — {len(ingested)} invoices, {errors} errors")

    return {
        **state,
        "ingested_invoices": ingested,
        "ingestion_errors":  errors,
        "run_id":            run_id,
    }

# (Leaving this function here just in case you ever want to revert)


def _generate_demo_invoices(client_id: str, count: int) -> list[dict]:
    suppliers = [
        "Reliance Industries", "Tata Consultancy", "Infosys Ltd",
        "HDFC Traders", "Sharma Enterprises", "Mehta Supplies",
        "Rajesh & Co", "Kumar Brothers", "Patel Industries",
    ]
    invoices = []
    for i in range(count):
        is_suspicious = random.random() < 0.15
        amount = (
            random.choice([100000, 200000, 500000])
            if is_suspicious
            else round(random.uniform(5000, 80000), 2)
        )
        invoices.append({
            "id":         f"INV-{1000 + i}",
            "client_id":  client_id,
            "date":       f"2026-03-{random.randint(1, 28):02d}",
            "party_name": random.choice(suppliers),
            "gstin":      f"27{''.join(random.choices('ABCDEFGHIJKLMNOP', k=5))}1234A1Z5",
            "amount":     amount,
            "gst_type":   random.choice(["PURCHASE", "SALES"]),
            "source":     "demo",
            "status":     "ingested",
        })
    return invoices


# ── AGENT 2: RECONCILIATION (REASON) ─────────────────────────

async def reconciliation_agent(state: PipelineState) -> PipelineState:
    print(
        f"[Reconciliation] Processing {len(state['ingested_invoices'])} invoices...")

    detector = get_detector()
    tracker = get_tracker()
    invoices = state["ingested_invoices"]

    scored = detector.predict_anomaly(invoices)
    reconciled = []
    matched = 0
    mismatched = 0
    anomalies = []

    for inv in scored:
        anomaly_score = inv.get("anomaly_score", 0)
        is_anomaly = inv.get("is_anomaly", False)
        match_prob = 0.40 if is_anomaly else 0.85
        gstr2a_match = random.random() < match_prob
        mismatch_reason = None

        if not gstr2a_match:
            mismatched += 1
            raw_reason = random.choice([
                "Amount mismatch — invoice differs from GSTR-2A entry",
                "GSTIN not found in GSTR-2A for this period",
                "Duplicate invoice detected in upload",
                "Invoice date outside filing period",
                "Supplier has not filed GSTR-1 this month",
            ])

            if llm:
                try:
                    response = llm.invoke(
                        f"You are a GST compliance assistant for Indian CA firms. "
                        f"A GST invoice mismatch was detected: '{raw_reason}'. "
                        f"Invoice amount: ₹{inv['amount']}. Party: {inv['party_name']}. "
                        f"In 1 sentence, explain what the CA should do to fix this. "
                        f"Be specific and practical. No preamble."
                    )
                    mismatch_reason = response.content
                except Exception:
                    mismatch_reason = raw_reason
            else:
                mismatch_reason = raw_reason
        else:
            matched += 1

        result = {
            **inv,
            "gstr2a_match":    gstr2a_match,
            "mismatch_reason": mismatch_reason,
            "anomaly_score":   anomaly_score,
            "is_anomaly":      is_anomaly,
            "status":          "matched" if gstr2a_match else "mismatch",
        }
        reconciled.append(result)

        if is_anomaly or not gstr2a_match:
            anomalies.append(result)

    mismatch_rate = mismatched / len(reconciled) if reconciled else 0
    anomaly_rate = len([a for a in anomalies if a.get(
        "is_anomaly")]) / len(reconciled) if reconciled else 0
    risk_score = round((mismatch_rate * 60 + anomaly_rate * 40), 1)

    tracker.log_reconciliation(
        total=len(reconciled),
        matched=matched,
        mismatched=mismatched,
        risk_score=risk_score,
    )
    tracker.log_anomalies([a for a in anomalies if a.get("is_anomaly")])

    print(
        f"[Reconciliation] Done — {matched} matched, {mismatched} mismatched, risk: {risk_score}")

    return {
        **state,
        "reconciled_invoices": reconciled,
        "matched_count":       matched,
        "mismatch_count":      mismatched,
        "anomalies":           anomalies,
        "risk_score":          risk_score,
    }


# ── AGENT 3: FILING (ACT) ─────────────────────────────────────

async def filing_agent(state: PipelineState) -> PipelineState:
    print(f"[Filing] Preparing GSTR-3B for {state['client_name']}...")

    tracker = get_tracker()
    reconciled = state["reconciled_invoices"]
    matched = [inv for inv in reconciled if inv.get("status") == "matched"]

    total_taxable = sum(inv["amount"] for inv in matched)
    total_cgst = round(total_taxable * 0.09, 2)
    total_sgst = round(total_taxable * 0.09, 2)
    total_igst = 0.0

    filing_payload = {
        "gstin":        state.get("client_gstin", "27AAPCS1234A1Z5"),
        "ret_period":   state["period"].replace("-", ""),
        "return_type":  "GSTR3B",
        "submitted_at": datetime.utcnow().isoformat(),
        "summary": {
            "total_invoices": len(matched),
            "total_taxable":  total_taxable,
            "total_cgst":     total_cgst,
            "total_sgst":     total_sgst,
            "total_igst":     total_igst,
            "total_tax":      round(total_cgst + total_sgst + total_igst, 2),
        },
        "invoices": [
            {
                "invoice_id": inv["id"],
                "party_name": inv["party_name"],
                "gstin":      inv.get("gstin", ""),
                "amount":     inv["amount"],
                "gst_type":   inv["gst_type"],
            }
            for inv in matched
        ],
        "exceptions_held_back": len(state["anomalies"]),
    }

    nic_reference = f"NIC{datetime.utcnow().strftime('%Y%m%d%H%M%S')}{random.randint(100, 999)}"
    filing_status = "filed"

    tracker.log_filing(
        return_type="GSTR-3B",
        status=filing_status,
        nic_reference=nic_reference,
        duration_seconds=1.2,
    )

    print(f"[Filing] Done — {filing_status}, ref: {nic_reference}")

    return {
        **state,
        "filing_payload": filing_payload,
        "filing_status":  filing_status,
        "nic_reference":  nic_reference,
    }


# ── CONDITIONAL EDGE ──────────────────────────────────────────

def should_file(state: PipelineState) -> str:
    if state["risk_score"] > 80:
        print(
            f"[Router] Risk {state['risk_score']} too high — skipping auto-filing")
        return "skip_filing"
    return "file"


# ── AGENT 4: LEARNING (REFLECT) ───────────────────────────────

async def learning_agent(state: PipelineState) -> PipelineState:
    print(
        f"[Learning] Updating model with {len(state['reconciled_invoices'])} records...")

    tracker = get_tracker()
    detector = get_detector()

    confirmed_anomaly_ids = [
        inv["id"] for inv in state["anomalies"]
        if not inv.get("gstr2a_match") and inv.get("is_anomaly")
    ]

    metrics = retrain_and_log(
        detector=detector,
        new_invoices=state["reconciled_invoices"],
        confirmed_anomalies=confirmed_anomaly_ids,
    )

    tracker.end_run(status="FINISHED")
    print(f"[Learning] Done — F1: {metrics.get('f1_score', 0):.4f}")

    return {
        **state,
        "model_metrics": metrics,
        "completed_at":  datetime.utcnow().isoformat(),
    }


# ── BUILD THE GRAPH ───────────────────────────────────────────

def build_pipeline() -> StateGraph:
    graph = StateGraph(PipelineState)

    graph.add_node("ingestion",      ingestion_agent)
    graph.add_node("reconciliation", reconciliation_agent)
    graph.add_node("filing",         filing_agent)
    graph.add_node("learning",       learning_agent)

    graph.set_entry_point("ingestion")
    graph.add_edge("ingestion", "reconciliation")
    graph.add_conditional_edges(
        "reconciliation",
        should_file,
        {
            "file":        "filing",
            "skip_filing": "learning",
        }
    )
    graph.add_edge("filing",   "learning")
    graph.add_edge("learning", END)

    return graph.compile()


pipeline = build_pipeline()


async def run_pipeline(
    client_id:    str,
    client_name:  str,
    period:       str,
    ca_email:     str,
    invoices:     list[dict] = None,
    client_gstin: str = "",
) -> dict:

    initial_state: PipelineState = {
        "client_id":           client_id,
        "client_name":         client_name,
        "period":              period,
        "ca_email":            ca_email,
        "invoices":            invoices or [],
        "client_gstin":        client_gstin,
        "ingestion_source":    "excel_upload" if invoices else "manual",
        "ingested_invoices":   [],
        "ingestion_errors":    0,
        "reconciled_invoices": [],
        "matched_count":       0,
        "mismatch_count":      0,
        "anomalies":           [],
        "risk_score":          0.0,
        "filing_payload":      {},
        "filing_status":       "pending",
        "nic_reference":       None,
        "model_metrics":       {},
        "run_id":              None,
        "errors":              [],
        "completed_at":        None,
    }

    final_state = await pipeline.ainvoke(initial_state)

    return {
        "client_id":      final_state["client_id"],
        "client_name":    final_state["client_name"],
        "period":         final_state["period"],
        "run_id":         final_state["run_id"],
        "total_invoices": len(final_state["ingested_invoices"]),
        "matched":        final_state["matched_count"],
        "mismatched":     final_state["mismatch_count"],
        "anomalies":      len(final_state["anomalies"]),
        "risk_score":     final_state["risk_score"],
        "filing_status":  final_state["filing_status"],
        "nic_reference":  final_state["nic_reference"],
        "model_metrics":  final_state["model_metrics"],
        "completed_at":   final_state["completed_at"],
        "exceptions":     final_state["anomalies"][:10],
    }
