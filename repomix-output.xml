"""
ai_routes.py — FastAPI routes that trigger the AI pipeline

Connects the 4-agent LangGraph pipeline to your existing FastAPI app.
Add this router to main.py with:  app.include_router(ai_router)
"""

from fastapi import APIRouter, Depends, HTTPException, BackgroundTasks
from pydantic import BaseModel
from typing import Optional
from datetime import datetime

from backend.dependencies import get_current_user
from backend.database import clients_collection, invoices_collection, reconciliations_collection, filings_collection
from backend.agents import run_pipeline
from backend.ml_model import get_detector
from bson import ObjectId

ai_router = APIRouter(prefix="/ai", tags=["AI Pipeline"])


# ── REQUEST / RESPONSE MODELS ─────────────────────────────────

class RunPipelineRequest(BaseModel):
    client_id:  str
    period:     str = "03-2026"   # MM-YYYY
    use_stored_invoices: bool = True  # use invoices already in DB


class PipelineResponse(BaseModel):
    client_id:      str
    client_name:    str
    period:         str
    run_id:         Optional[str]
    total_invoices: int
    matched:        int
    mismatched:     int
    anomalies:      int
    risk_score:     float
    filing_status:  str
    nic_reference:  Optional[str]
    model_metrics:  dict
    completed_at:   Optional[str]
    exceptions:     list


# ── ROUTES ────────────────────────────────────────────────────

@ai_router.post("/run", response_model=PipelineResponse)
async def run_agent_pipeline(
    req:          RunPipelineRequest,
    current_user=Depends(get_current_user),
):
    """
    Trigger the full 4-agent pipeline for a client.

    This is the main endpoint that:
    1. Fetches client + invoices from MongoDB
    2. Runs Ingestion → Reconciliation → Filing → Learning
    3. Saves results back to MongoDB
    4. Returns a full summary
    """

    # Fetch client
    client = await clients_collection.find_one({"_id": ObjectId(req.client_id)})
    if not client:
        raise HTTPException(status_code=404, detail="Client not found")

    # Fetch invoices from DB if requested
    invoices = []
    if req.use_stored_invoices:
        raw = await invoices_collection.find(
            {"client_id": req.client_id, "status": "pending"}
        ).to_list(length=500)

        invoices = [
            {
                "id":          str(inv["_id"]),
                "client_id":   inv["client_id"],
                "date":        inv.get("date", ""),
                "party_name":  inv.get("party_name", ""),
                "gstin":       inv.get("gstin", ""),
                "amount":      float(inv.get("amount", 0)),
                "gst_type":    inv.get("gst_type", "PURCHASE"),
                "source":      inv.get("source", "manual"),
                "status":      "pending",
            }
            for inv in raw
        ]

    # Run the pipeline
    try:
        result = await run_pipeline(
            client_id=str(client["_id"]),
            client_name=client["name"],
            period=req.period,
            ca_email=current_user["email"],
            invoices=invoices,
            client_gstin=client.get("gstin", ""),
        )
    except Exception as e:
        raise HTTPException(
            status_code=500, detail=f"Pipeline error: {str(e)}")

    # Safely extract risk score in case the AI agent misses it
    risk_score = float(result.get("risk_score", 0.0))

    # Save reconciliation results back to MongoDB
    if result.get("exceptions"):
        rec_docs = [
            {
                "client_id":       req.client_id,
                "invoice_id":      exc.get("id", ""),
                "party_name":      exc.get("party_name", ""),
                "amount":          exc.get("amount", 0),
                "gstr2a_match":    exc.get("gstr2a_match", False),
                "mismatch_reason": exc.get("mismatch_reason", ""),
                "anomaly_score":   exc.get("anomaly_score", 0),
                "is_anomaly":      exc.get("is_anomaly", False),
                "status":          "mismatch",
                "period":          req.period,
                "reconciled_at":   datetime.utcnow().isoformat(),
            }
            for exc in result["exceptions"]
        ]
        if rec_docs:
            await reconciliations_collection.insert_many(rec_docs)

    # Save filing record
    if result.get("filing_status") in ("filed", "pending"):
        await filings_collection.insert_one({
            "client_id":     req.client_id,
            "client_name":   client["name"],
            "period":        req.period,
            "return_type":   "GSTR-3B",
            "status":        result.get("filing_status"),
            "nic_reference": result.get("nic_reference"),
            "risk_score":    risk_score,
            "run_id":        result.get("run_id"),
            "filed_at":      datetime.utcnow().isoformat(),
            "created_at":    datetime.utcnow().isoformat(),
        })

    # Update client risk score
    await clients_collection.update_one(
        {"_id": ObjectId(req.client_id)},
        {"$set": {"risk_score": risk_score}}
    )

    # Merge the LangGraph result with the request context to perfectly satisfy Pydantic
    return {
        "client_id": req.client_id,
        "client_name": client["name"],
        "period": req.period,
        "run_id": result.get("run_id"),
        "total_invoices": result.get("total_invoices", len(invoices)),
        "matched": result.get("matched", 0),
        "mismatched": result.get("mismatched", 0),
        "anomalies": result.get("anomalies", 0),
        "risk_score": risk_score,
        "filing_status": result.get("filing_status", "pending"),
        "nic_reference": result.get("nic_reference"),
        "model_metrics": result.get("model_metrics", {}),
        "completed_at": datetime.utcnow().isoformat(),
        "exceptions": result.get("exceptions", [])
    }


@ai_router.get("/status")
async def get_ai_status(current_user=Depends(get_current_user)):
    """
    Returns current status of the AI system.
    Used by the frontend Agent Status view.
    """
    detector = get_detector()
    return {
        "model_trained":   detector.is_trained,
        "agents": [
            {"name": "Ingestion",      "status": "ready", "sub": "Perceive"},
            {"name": "Reconciliation", "status": "ready", "sub": "Reason"},
            {"name": "Filing",         "status": "ready", "sub": "Act"},
            {"name": "Learning",       "status": "ready", "sub": "Reflect"},
        ],
        "mlflow_tracking": "./mlruns",
        "version": "1.0.0",
    }


@ai_router.post("/score-invoices")
async def score_invoices(
    payload: dict,
    current_user=Depends(get_current_user),
):
    """
    Score a list of invoices for anomalies using XGBoost.
    Quick endpoint for testing the ML model directly.
    """
    invoices = payload.get("invoices", [])
    if not invoices:
        raise HTTPException(status_code=400, detail="No invoices provided")

    detector = get_detector()
    scored = detector.predict_anomaly(invoices)

    return {
        "total":     len(scored),
        "anomalies": sum(1 for s in scored if s.get("is_anomaly")),
        "results":   scored,
    }
