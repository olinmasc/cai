import { useState, useEffect } from "react";
import {
  Users, Clock, AlertTriangle, CheckCircle,
  RefreshCw, Download, ArrowUpRight,
} from "lucide-react";
import {
  ResponsiveContainer, BarChart, Bar, XAxis, YAxis,
  CartesianGrid, Tooltip,
} from "recharts";
import { api } from "../lib/api.js";
import { useToast } from "../hooks/useToast.jsx";
import { RiskScore, StatusBadge, SkeletonRow, EmptyState } from "../components/ui/UI.jsx";

function MetricCard({ icon: Icon, label, value, sub, color = "var(--accent)", loading }) {
  return (
    <div
      className="card metric-card"
      style={{ padding: 20 }}
    >
      <div style={{ display: "flex", alignItems: "flex-start", justifyContent: "space-between", marginBottom: 16 }}>
        <div
          style={{
            width: 32,
            height: 32,
            borderRadius: 7,
            background: `${color}18`,
            border: `1px solid ${color}30`,
            display: "flex",
            alignItems: "center",
            justifyContent: "center",
          }}
        >
          <Icon size={15} style={{ color }} />
        </div>
        <ArrowUpRight size={13} style={{ color: "var(--text-3)" }} />
      </div>
      {loading ? (
        <div style={{ height: 36, display: "flex", alignItems: "center" }}>
          <div className="skeleton" style={{ width: 60, height: 24 }} />
        </div>
      ) : (
        <div
          className="mono"
          style={{ fontSize: 26, fontWeight: 600, color: "var(--text)", lineHeight: 1, marginBottom: 6 }}
        >
          {value}
        </div>
      )}
      <div style={{ fontSize: 12.5, color: "var(--text-2)" }}>{label}</div>
      {sub && <div style={{ fontSize: 11.5, color: "var(--text-3)", marginTop: 3 }}>{sub}</div>}
    </div>
  );
}

const CustomTooltip = ({ active, payload }) => {
  if (!active || !payload?.length) return null;
  return (
    <div
      style={{
        background: "var(--surface-2)",
        border: "1px solid var(--border-2)",
        borderRadius: 6,
        padding: "8px 12px",
        fontSize: 12,
      }}
    >
      <div style={{ color: "var(--text-2)", marginBottom: 4 }}>{payload[0]?.payload?.name}</div>
      <div className="mono" style={{ color: "var(--accent)", fontWeight: 600 }}>
        Risk: {payload[0]?.value}
      </div>
    </div>
  );
};

export default function DashboardPage({ user, onRunPipeline }) {
  const toast                   = useToast();
  const [clients, setClients]   = useState([]);
  const [filings, setFilings]   = useState([]);
  const [loading, setLoading]   = useState(true);
  const [exporting, setExporting] = useState(null); // clientId being exported
  const isAdmin                 = user?.role === "Admin";

  const load = async () => {
    setLoading(true);
    const [{ data: c }, { data: f }] = await Promise.all([
      api.get("/clients/"),
      api.get("/filings/"),
    ]);
    setClients(Array.isArray(c) ? c : []);
    setFilings(Array.isArray(f) ? f : []);
    setLoading(false);
  };

  useEffect(() => { load(); }, []);

  async function downloadReport(clientId, format) {
    if (!isAdmin) { toast("Export is restricted to Admin users.", "warning"); return; }
    setExporting(`${clientId}-${format}`);

    const { blob, error } = await api.download(
      `/reconciliation/export-report/${clientId}?format=${format}`
    );

    if (error) {
      toast(error, "error");
    } else {
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = `Mismatch_Report.${format === "excel" ? "xlsx" : "pdf"}`;
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);
      toast("Report downloaded.", "success");
    }
    setExporting(null);
  }

  const pending  = filings.filter((f) => f.status === "pending").length;
  const filed    = filings.filter((f) => f.status === "filed").length;
  const highRisk = clients.filter((c) => (c.risk_score || 0) > 70).length;

  const chartData = clients
    .filter((c) => (c.risk_score || 0) > 0)
    .map((c) => ({ name: c.name, risk: c.risk_score || 0 }));

  return (
    <div style={{ padding: "28px 32px", maxWidth: 1200 }}>
      {/* Header */}
      <div className="page-header">
        <div>
          <div className="page-title">Dashboard</div>
          <div className="page-subtitle">
            {user?.firm_name || "CA Firm"} &mdash; March 2026
          </div>
        </div>
        <button
          onClick={load}
          disabled={loading}
          className="btn btn-secondary btn-sm"
        >
          <RefreshCw size={12} className={loading ? "animate-spin" : ""} />
          Refresh
        </button>
      </div>

      {/* Metrics */}
      <div style={{ display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: 14, marginBottom: 28 }}>
        <MetricCard
          icon={Users}
          label="Total Clients"
          value={loading ? "—" : clients.length}
          sub="Registered this quarter"
          color="var(--accent)"
          loading={loading}
        />
        <MetricCard
          icon={Clock}
          label="Pending Filings"
          value={loading ? "—" : pending}
          sub="Awaiting action"
          color="var(--warning)"
          loading={loading}
        />
        <MetricCard
          icon={AlertTriangle}
          label="High Risk"
          value={loading ? "—" : highRisk}
          sub="Risk score above 70"
          color="var(--danger)"
          loading={loading}
        />
        <MetricCard
          icon={CheckCircle}
          label="Filed"
          value={loading ? "—" : filed}
          sub="Completed this cycle"
          color="var(--info)"
          loading={loading}
        />
      </div>

      {/* Chart */}
      {(loading || chartData.length > 0) && (
        <div className="card" style={{ padding: 20, marginBottom: 28 }}>
          <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", marginBottom: 20 }}>
            <div>
              <div style={{ fontSize: 13.5, fontWeight: 600, color: "var(--text)" }}>
                Portfolio Risk Analysis
              </div>
              <div style={{ fontSize: 12, color: "var(--text-2)", marginTop: 2 }}>
                AI-assessed anomaly scores per client
              </div>
            </div>
            <div
              style={{
                fontSize: 11,
                color: "var(--text-3)",
                background: "var(--surface-2)",
                border: "1px solid var(--border)",
                borderRadius: 4,
                padding: "4px 8px",
                fontFamily: "'IBM Plex Mono', monospace",
              }}
            >
              XGBoost v1.0
            </div>
          </div>

          {loading ? (
            <div style={{ height: 220 }} className="skeleton" />
          ) : (
            <div style={{ height: 220 }}>
              <ResponsiveContainer width="100%" height="100%">
                <BarChart
                  data={chartData}
                  margin={{ top: 0, right: 0, left: -20, bottom: 0 }}
                >
                  <CartesianGrid
                    strokeDasharray="2 4"
                    stroke="var(--border)"
                    vertical={false}
                  />
                  <XAxis
                    dataKey="name"
                    stroke="var(--text-3)"
                    fontSize={11.5}
                    tickLine={false}
                    axisLine={false}
                    fontFamily="IBM Plex Sans"
                  />
                  <YAxis
                    stroke="var(--text-3)"
                    fontSize={11}
                    tickLine={false}
                    axisLine={false}
                    domain={[0, 100]}
                    fontFamily="IBM Plex Mono"
                  />
                  <Tooltip content={<CustomTooltip />} cursor={{ fill: "var(--surface-2)" }} />
                  <Bar
                    dataKey="risk"
                    fill="var(--accent)"
                    radius={[3, 3, 0, 0]}
                    maxBarSize={40}
                  />
                </BarChart>
              </ResponsiveContainer>
            </div>
          )}
        </div>
      )}

      {/* Client table */}
      <div>
        <div className="section-label">Client Portfolio</div>
        <div className="card" style={{ overflow: "hidden" }}>
          <table className="data-table">
            <thead>
              <tr>
                {["Client", "GSTIN", "Plan", "Risk Score", "Reports"].map((h) => (
                  <th key={h}>{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {loading ? (
                <>
                  <SkeletonRow cols={5} />
                  <SkeletonRow cols={5} />
                  <SkeletonRow cols={5} />
                </>
              ) : clients.length === 0 ? (
                <tr>
                  <td colSpan={5} style={{ padding: 0 }}>
                    <EmptyState
                      icon={Users}
                      title="No clients yet"
                      description="Go to the Clients page to add your first client."
                    />
                  </td>
                </tr>
              ) : (
                clients.map((client) => (
                  <tr key={client.id}>
                    <td>
                      <div style={{ fontWeight: 500, color: "var(--text)", fontSize: 13 }}>
                        {client.name}
                      </div>
                    </td>
                    <td>
                      <span className="mono" style={{ color: "var(--text-2)" }}>
                        {client.gstin}
                      </span>
                    </td>
                    <td>
                      <span
                        style={{
                          fontSize: 12,
                          textTransform: "capitalize",
                          color: "var(--text-2)",
                        }}
                      >
                        {client.plan_type}
                      </span>
                    </td>
                    <td>
                      <RiskScore score={client.risk_score || 0} />
                    </td>
                    <td>
                      <div style={{ display: "flex", gap: 6 }}>
                        <button
                          onClick={() => downloadReport(client.id, "excel")}
                          disabled={!isAdmin || exporting === `${client.id}-excel`}
                          className="btn btn-ghost btn-sm"
                          style={{ color: "var(--accent)" }}
                        >
                          <Download size={11} />
                          {exporting === `${client.id}-excel` ? "..." : "Excel"}
                        </button>
                        <button
                          onClick={() => downloadReport(client.id, "pdf")}
                          disabled={!isAdmin || exporting === `${client.id}-pdf`}
                          className="btn btn-ghost btn-sm"
                          style={{ color: "var(--danger)" }}
                        >
                          <Download size={11} />
                          {exporting === `${client.id}-pdf` ? "..." : "PDF"}
                        </button>
                      </div>
                    </td>
                  </tr>
                ))
              )}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  );
}
